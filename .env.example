# calmcp configuration (local / stdio development).
# On SAP BTP these values come from the bound Destination service instead — see README.

# --- Sandbox mode (SAP Business Accelerator Hub) ---
# When true, calls go to https://sandbox.api.sap.com/SAPCALM using a static API key.
CALM_SANDBOX=false
CALM_API_KEY=

# --- OAuth2 client-credentials mode (productive tenant) ---
# Required when CALM_SANDBOX=false and no Destination is bound.
CALM_TENANT=
CALM_REGION=eu10
CALM_CLIENT_ID=
CALM_CLIENT_SECRET=

# --- HTTP transport (BTP / remote clients) ---
PORT=8080
# Comma-separated list of allowed CORS origins for the HTTP transport ("*" to allow all).
CALM_CORS_ORIGINS=*
# Optional shared secret guarding the /mcp endpoint. Callers send "Authorization: Bearer <key>".
# Use this for Microsoft Copilot Studio or other API-key clients. Generate with: openssl rand -base64 48
# Leave empty locally; on BTP an enabled key (and/or the bound XSUAA service) protects /mcp.
CALM_HTTP_API_KEY=

# --- Behaviour ---
CALM_DEBUG=false
CALM_TIMEOUT_SECONDS=30
CALM_TOKEN_REFRESH_BUFFER_SECONDS=5
# Name of the bound BTP destination pointing at the Cloud ALM API (HTTP transport on BTP).
CALM_DESTINATION_NAME=SAP_CALM
