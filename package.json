{
  "name": "calmcp",
  "version": "0.1.0",
  "description": "Read-only Model Context Protocol (MCP) server bridging AI assistants to SAP Cloud ALM. Deployable to SAP BTP Cloud Foundry.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "calmcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:mcpb": "npm run build && node scripts/build-mcpb.mjs",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --http",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "format": "biome format --write src tests",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@arc-mcp/xsuaa-auth": "^0.1.3",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@sap-cloud-sdk/connectivity": "^4.7.0",
    "commander": "^15.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "pino": "^9.5.0",
    "undici": "^8.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.20",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.8",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^5.7.3",
    "vitest": "^4.1.1"
  }
}
